{% extends 'base.html.twig' %}

{% block title %}Paiement index{% endblock %}

{% block body %}
    <h1>Paiement index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Amountincents</th>
                <th>Payment_date</th>
                <th>PaymentMethod</th>
                <th>Statut</th>
                <th>Reference_transaction</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for paiement in paiements %}
            <tr>
                <td>{{ paiement.id }}</td>
                <td>{{ paiement.amountincents }}</td>
                <td>{{ paiement.paymentDate ? paiement.paymentDate|date('Y-m-d H:i:s') : '' }}</td>
                <td>{{ paiement.paymentMethod }}</td>
                <td>{{ paiement.statut }}</td>
                <td>{{ paiement.referenceTransaction }}</td>
                <td>
                    <a href="{{ path('app_paiement_show', {'id': paiement.id}) }}">show</a>
                    <a href="{{ path('app_paiement_edit', {'id': paiement.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="7">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_paiement_new') }}">Create new</a>
{% endblock %}
