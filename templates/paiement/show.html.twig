{% extends 'base.html.twig' %}

{% block title %}Paiement{% endblock %}

{% block body %}
    <h1>Paiement</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ paiement.id }}</td>
            </tr>
            <tr>
                <th>Amountincents</th>
                <td>{{ paiement.amountincents }}</td>
            </tr>
            <tr>
                <th>Payment_date</th>
                <td>{{ paiement.paymentDate ? paiement.paymentDate|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>PaymentMethod</th>
                <td>{{ paiement.paymentMethod }}</td>
            </tr>
            <tr>
                <th>Statut</th>
                <td>{{ paiement.statut }}</td>
            </tr>
            <tr>
                <th>Reference_transaction</th>
                <td>{{ paiement.referenceTransaction }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_paiement_index') }}">back to list</a>

    <a href="{{ path('app_paiement_edit', {'id': paiement.id}) }}">edit</a>

    {{ include('paiement/_delete_form.html.twig') }}
{% endblock %}
